        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.13.12",
        "@types/react-grid-layout": "^1.3.5",
        "axios": "^1.12.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "echarts": "^5.6.0",
        "echarts-for-react": "^3.0.2",
        "framer-motion": "^12.23.9",
        "lucide-react": "^0.525.0",
        "miragejs": "^0.1.48",
        "next": "^16.1.6",
        "next-mdx-remote": "^6.0.0",
        "next-themes": "^0.4.6",
        "papaparse": "^5.5.3",
        "react": "^19.2.0",
        "react-day-picker": "^9.8.0",
        "react-dom": "^19.2.0",
        "react-grid-layout": "^1.5.2",
        "react-hook-form": "^7.61.1",
        "recharts": "^3.1.0",
        "rehype-highlight": "^7.0.2",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "sonner": "^2.0.6",
        "tailwind-merge": "^3.3.1",
        "tailwindcss": "^4.0.0",
        "zod": "^4.0.8",
        "zustand": "^5.0.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.11",
        "@types/node": "^20.9.0",
        "@types/papaparse": "^5.3.14",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "eslint": "^9.0.0",
        "eslint-config-next": "^16.2.1",
        "husky": "^8.0.3",
        "lint-staged": "^15.1.0",
        "postcss": "^8.5.6",
        "prettier": "^3.1.0",
        "prettier-plugin-tailwindcss": "^0.5.7",
        "typescript": "^5.2.2",
        "typescript-eslint": "8.54.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --cache --fix",
            "prettier --write"
        ],
        "*.{json,md,mdx,css,html}": [
            "prettier --write"
        ]
    },
    "keywords": [
        "nextjs",
        "admin-template",
        "dashboard",
        "typescript",
        "tailwindcss",
        "themes",
        "react"
    ],
    "author": "Ali Morshedzadeh",
